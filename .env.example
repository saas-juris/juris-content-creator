# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME="Juris Content Engine"

# ─── NextAuth ────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
NEXTAUTH_SECRET=your_secret_here_generate_with_openssl_rand_hex_32
# Set to your domain in production (e.g. https://cms.juris.av.tr)
NEXTAUTH_URL=http://localhost:3000

# ─── Database ────────────────────────────────────────────────────────────────
# SQLite (local dev)
DATABASE_URL="file:./dev.db"
# PostgreSQL (production — Railway provides this automatically)
# DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# ─── AI ──────────────────────────────────────────────────────────────────────
# Anthropic Claude API key — can also be set via Settings page in the app
ANTHROPIC_API_KEY=sk-ant-...

# ─── Storage ─────────────────────────────────────────────────────────────────
# Local file storage path (dev only)
STORAGE_PATH=./storage
# S3-compatible storage (production — Phase 2)
# S3_BUCKET=your_bucket_name
# S3_REGION=auto
# S3_ACCESS_KEY_ID=your_access_key
# S3_SECRET_ACCESS_KEY=your_secret_key
# S3_ENDPOINT=https://your-account.r2.cloudflarestorage.com
