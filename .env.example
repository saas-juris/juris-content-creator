# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME="Juris Content Engine"

# ─── NextAuth ────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NEXTAUTH_SECRET=your_secret_here_32_bytes_hex
# Local dev → http://localhost:3000
# Railway   → https://your-app.up.railway.app  (or custom domain)
NEXTAUTH_URL=http://localhost:3000

# ─── Database ────────────────────────────────────────────────────────────────
# Local dev — SQLite file (default, no change needed)
DATABASE_URL=file:./dev.db

# Railway Option A — Railway Volume (add a Volume in Railway dashboard, mount at /data)
# DATABASE_URL=file:/data/juris.db

# Railway Option B — Turso cloud SQLite (sign up at turso.tech, free tier available)
# DATABASE_URL=libsql://your-db-name.turso.io?authToken=your_token_here

# ─── AI ──────────────────────────────────────────────────────────────────────
# Anthropic Claude API key — can also be set via Settings page in the app
ANTHROPIC_API_KEY=sk-ant-...

# ─── Storage (File Uploads) ───────────────────────────────────────────────────
# Local dev (default, no change needed — creates ./storage/ automatically)
STORAGE_PATH=./storage

# Railway — must point to a persistent Volume mount path
# STORAGE_PATH=/data/storage

# ─── Puppeteer (PDF/PNG export) ───────────────────────────────────────────────
# Local dev — leave empty, Puppeteer downloads Chromium automatically
# PUPPETEER_EXECUTABLE_PATH=

# Railway — Chromium installed by Nixpacks (set automatically via railway.toml)
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium-browser
# PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=true

# ─── First-run Admin Seed ─────────────────────────────────────────────────────
# Used only during first `pnpm db:seed` run (when no users exist)
# Change these before deploying!
ADMIN_EMAIL=admin@juris.av.tr
ADMIN_PASSWORD=JurisAdmin2025!
